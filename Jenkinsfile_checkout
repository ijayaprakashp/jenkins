pipeline {
    agent any

    parameters {
        booleanParam(name: 'DEPLOY', description: 'Deploy to production?')
    }

    environment {
        CURRENT_ENV = 'prod'
    }

    stages {
        stage('Checkout_Repo') {
            steps {
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: '*/main']],
                    doGenerateSubmoduleConfigurations: false,
                    extensions: [],
                    userRemoteConfigs: [[
                        url: 'https://github.com/ijayaprakashp/jenkins.git'
                    ]]
                ])
                echo "Repository checked out"
            }
        }

        stage('Main_Branch') {
            when { branch 'main' }
            steps {
                echo "This is the main branch stage"
                sh '''
                echo "Main Branch"
                sleep 5
                '''
            }
        }

        stage('Environment_Prod') {
            when { environment name: 'CURRENT_ENV', value: 'prod' }
            steps {
                echo "This is the prod environment stage"
                sh '''
                echo "When Environment"
                sleep 5
                '''
            }
        }

        stage('Deploy_If_Parameter_True') {
            when { expression { params.DEPLOY == true } }
            steps {
                echo "DEPLOY parameter is true"
                sh '''
                echo "Deploying because parameter is true"
                sleep 5
                '''
            }
        }
    }
}