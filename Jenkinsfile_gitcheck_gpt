pipeline {
    agent any

    parameters {
        booleanParam(name: 'DEPLOY', description: 'want to deploy to production')
    }

    environment {
        CURRENT_ENV = 'prod'
    }

    stages {

        stage('Checkout_Repo') {
            steps {
                // Simplified checkout using declarative git step
                git branch: 'main', url: 'https://github.com/ijayaprakashp/jenkins.git'
                
                echo "Repository checked out"

                // Capture current branch in environment variable
                script {
                    env.GIT_BRANCH_NAME = sh(
                        script: "git rev-parse --abbrev-ref HEAD",
                        returnStdout: true
                    ).trim()
                }

                sh '''
                    echo GIT_BRANCH_NAME: $GIT_BRANCH_NAME
                    pwd
                    ls -lrt
                '''
            }
        }

        stage('WHEN_MAIN_BRANCH') {
            when {
                expression {
                    return env.GIT_BRANCH_NAME == 'main'
                }
            }
            steps {
                echo "This is stage 1 - running on main branch"
                sh '''
                    pwd
                    ls -lrt
                    sleep 5
                '''
            }
        }

        stage('when environment') {
            when {
                environment name: 'CURRENT_ENV', value: 'prod'
            }
            steps {
                echo "This is stage 2"
                sh '''
                    pwd
                    ls -lrt
                    sleep 5
                '''
            }
        }

        stage('when parameter only') {
            when {
                expression { params.DEPLOY == true }
            }
            steps {
                echo "DEPLOY parameter is true"
                sh '''
                    echo "Deploying because parameter is true"
                    sleep 5
                '''
            }
        }

    }
}